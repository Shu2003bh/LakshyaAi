generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  imageUrl    String?
  industry    String?
  bio         String?
  experience  Int?
  skills      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments            Assessment[]
  coverLetters           CoverLetter[]
  resume                 Resume?
  roadmaps               SkillRoadmap[]
  skillXP                SkillXP[]
  interviewSessions      InterviewSession[]
  voiceInterviewSessions VoiceInterviewSession[]

  industryInsight IndustryInsight? @relation(fields: [industry], references: [industry])
}

model Assessment {
  id             String  @id @default(cuid())
  userId         String
  quizScore      Float
  questions      Json[]
  category       String
  improvementTip String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id       String  @id @default(cuid())
  userId   String  @unique
  content  String
  atsScore Float?
  feedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CoverLetter {
  id             String  @id @default(cuid())
  userId         String
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String  @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IndustryInsight {
  id                String   @id @default(cuid())
  industry          String   @unique
  salaryRanges      Json[]
  growthRate        Float?
  demandLevel       String?
  topSkills         String[]
  marketOutlook     String?
  keyTrends         String[]
  recommendedSkills String[]

  lastUpdated DateTime @default(now())
  nextUpdate  DateTime

  users User[]

  @@index([industry])
}

//////////////////////////////
// 🚀 ROADMAP SYSTEM
//////////////////////////////

model SkillRoadmap {
  id     String @id @default(cuid())
  userId String
  skill  String
  status String @default("active") // active | completed | archived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id])
  steps RoadmapStep[]

  @@unique([userId, skill])
  @@index([userId])
}

model RoadmapStep {
  id          String  @id @default(cuid())
  roadmapId   String
  title       String
  description String
  stepOrder   Int
  completed   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roadmap SkillRoadmap @relation(fields: [roadmapId], references: [id])

  @@index([roadmapId])
}

//////////////////////////////
// ⭐ GAMIFICATION ENGINE
//////////////////////////////

model SkillXP {
  id     String @id @default(cuid())
  userId String
  skill  String
  xp     Int    @default(0)
  level  Int    @default(1)
  streak Int    @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, skill])
}

//////////////////////////////////////
// 🚀 INTERVIEW QUESTION BANK
//////////////////////////////////////

model InterviewQuestion {
  id            String  @id @default(cuid())
  role          String
  question      String
  options       Json?
  correctAnswer String?
  difficulty    String  @default("Medium") // Easy | Medium | Hard
  category      String  @default("Technical") // Technical | DSA | System Design | HR | Behavioral
  explanation   String? // AI-generated explanation for correct answer

  createdAt DateTime @default(now())

  interviewAttempts InterviewAttempt[]

  @@index([role])
  @@index([difficulty])
  @@index([category])
}

//////////////////////////////////////
// ⭐ INTERVIEW SESSION ENGINE
//////////////////////////////////////

model InterviewSession {
  id          String    @id @default(cuid())
  userId      String
  role        String
  status      String    @default("active") // active | completed
  totalScore  Float?
  duration    Int?      @default(1200) // seconds
  startedAt   DateTime?
  endsAt      DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user     User               @relation(fields: [userId], references: [id])
  attempts InterviewAttempt[]

  @@index([userId])
}

model InterviewAttempt {
  id         String @id @default(cuid())
  sessionId  String
  questionId String

  userAnswer String?
  isCorrect  Boolean?
  score      Float?

  createdAt DateTime @default(now())

  session  InterviewSession  @relation(fields: [sessionId], references: [id])
  question InterviewQuestion @relation(fields: [questionId], references: [id])
}

//////////////////////////////////////
// 🎙️ VOICE INTERVIEW SESSION
//////////////////////////////////////

model VoiceInterviewSession {
  id          String   @id @default(cuid())
  userId      String
  role        String
  mode        String   // fresher | intermediate | advanced | faang
  duration    Int      // minutes
  totalScore  Float?
  feedback    String?
  scores      Json?    // Array of { skill, score, question }
  strongAreas String[]
  weakAreas   String[]
  status      String   @default("completed")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
